EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
EXPO_PUBLIC_OPENAI_API_KEY=your-openai-key-here
# RevenueCat App-specific public API keys (production)
# iOS keys start with `appl_`, Android with `goog_`.
# Get them from RevenueCat dashboard → Project settings → API keys.
# Do NOT use a `test_` key in TestFlight/App Store builds — RevenueCat will block the app.
EXPO_PUBLIC_REVENUECAT_IOS_KEY=appl_your_ios_key_here
EXPO_PUBLIC_REVENUECAT_ANDROID_KEY=goog_your_android_key_here
